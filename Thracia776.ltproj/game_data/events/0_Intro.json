                [
                    "Leif",
                    "Eyvel! Nanna's still in the village. I can't just leave her and run.{w}",
                    "",
                    "",
                    "noir"
                ]
            ],
            [
                "speak",
                [
                    "Eyvel",
                    "I'll ensure her safety. Don't worry.{w}",
