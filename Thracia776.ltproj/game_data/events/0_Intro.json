            ],
            [
                "speak",
                [
                    "Eyvel",
                    "What about you Finn?{w}{br}Are you going to allow Lord Leif to get himself in danger?{w}",
                    "",
                    "",
                    "noir"
                ]
            ],
            [
                "speak",
                [
                    "Finn",
                    "Lord Leif is already 15 years old.{w}{br}He's old enough to make his own decisions.{w}{br}As his servant, I'll respect his judgement and follow his commands.{w}",
                    "",
                    "",
                    "noir"
                ]
            ],
            [
                "speak",
                [
                    "Eyvel",
                    "15... Well, we did bring him with us to defeat the pirates.{w}{br}Fine, if Finn says so, it's all right with me.{w}",
                    "",
                    "",
                    "noir"
